<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20" style="-fx-background-color: #2c3e50;" prefWidth="400" prefHeight="500"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.my.pharmacy.controller.LoginController">

    <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);" maxWidth="350">

        <Label text="PHARMACY SYSTEM" textFill="#2c3e50">
            <font><Font name="System Bold" size="20.0"/></font>
        </Label>
        <Label text="WHOLESALE EDITION" textFill="#7f8c8d" style="-fx-font-size: 12px; -fx-padding: 0 0 20 0;"/>

        <VBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Username" style="-fx-font-weight: bold;"/>
            <TextField fx:id="usernameField" promptText="Enter username" style="-fx-padding: 10;"/>

            <Label text="Password" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="passwordField" promptText="Enter password" style="-fx-padding: 10;"/>
        </VBox>

        <Label fx:id="errorLabel" text="" textFill="#e74c3c" style="-fx-padding: 10 0 0 0;"/>

        <Button text="SECURE LOGIN" onAction="#handleLogin"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30; -fx-font-size: 14px; -fx-cursor: hand;"
                maxWidth="Infinity">
            <VBox.margin>
                <Insets top="20"/>
            </VBox.margin>
        </Button>
    </VBox>

    <Label text="Support: 0313-9451041" textFill="#bdc3c7" style="-fx-font-size: 11px;"/>

</VBox>