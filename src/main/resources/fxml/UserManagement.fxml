<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f4f7f6;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.my.pharmacy.controller.UserManagementController">

    <VBox spacing="15" prefWidth="350" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <Label text="Register New Staff" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

        <TextField fx:id="fullNameField" promptText="Full Name"/>
        <TextField fx:id="usernameField" promptText="Login Username"/>
        <PasswordField fx:id="passwordField" promptText="Password"/>

        <Label text="Account Role:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="roleComboBox" promptText="Select Role" maxWidth="Infinity"/>

        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
            <Button text="Clear" onAction="#clearFields" style="-fx-background-color: #bdc3c7;" prefWidth="100"/>
            <Button text="Create User" onAction="#handleSaveUser" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>
    </VBox>

    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Label text="SYSTEM USERS" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName" text="Full Name" prefWidth="180"/>
                <TableColumn fx:id="colUsername" text="Username" prefWidth="150"/>
                <TableColumn fx:id="colRole" text="Role" prefWidth="120"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            </columns>
        </TableView>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Deactivate Selected User" onAction="#handleToggleStatus" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        </HBox>
    </VBox>

</HBox>