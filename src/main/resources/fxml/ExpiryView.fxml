<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="16" style="-fx-background-color: #ecf0f1; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.my.pharmacy.controller.ExpiryController">

    <!-- Header -->
    <Label text="Expiry Management" style="-fx-text-fill: #2c3e50;">
        <font><Font name="System Bold" size="24.0"/></font>
    </Label>
    <Label text="Showing all batches expiring within the next 90 days, plus already-expired stock."
           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>

    <Separator/>

    <!-- Summary cards -->
    <HBox spacing="16">
        <VBox style="-fx-background-color: #f5b7b1; -fx-background-radius: 8; -fx-padding: 16;" HBox.hgrow="ALWAYS">
            <Label text="EXPIRED" style="-fx-font-weight: bold; -fx-text-fill: #922b21;"/>
            <Label fx:id="lblExpired" text="0" style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #922b21;"/>
            <Label text="Already expired" style="-fx-text-fill: #922b21; -fx-font-size: 11px;"/>
        </VBox>
        <VBox style="-fx-background-color: #fadbd8; -fx-background-radius: 8; -fx-padding: 16;" HBox.hgrow="ALWAYS">
            <Label text="CRITICAL (≤ 30 days)" style="-fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
            <Label fx:id="lblCritical" text="0" style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #c0392b;"/>
            <Label text="Expiring this month" style="-fx-text-fill: #c0392b; -fx-font-size: 11px;"/>
        </VBox>
        <VBox style="-fx-background-color: #fdebd0; -fx-background-radius: 8; -fx-padding: 16;" HBox.hgrow="ALWAYS">
            <Label text="WARNING (31–60 days)" style="-fx-font-weight: bold; -fx-text-fill: #d35400;"/>
            <Label fx:id="lblWarning" text="0" style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #d35400;"/>
            <Label text="Expiring within 2 months" style="-fx-text-fill: #d35400; -fx-font-size: 11px;"/>
        </VBox>
        <VBox style="-fx-background-color: #fef9e7; -fx-background-radius: 8; -fx-padding: 16;" HBox.hgrow="ALWAYS">
            <Label text="TOTAL ALERTS" style="-fx-font-weight: bold; -fx-text-fill: #7d6608;"/>
            <Label fx:id="lblTotal" text="0" style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #7d6608;"/>
            <Label text="Batches needing attention" style="-fx-text-fill: #7d6608; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <!-- Table + actions -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 5, 0, 0, 0);"
          spacing="12" VBox.vgrow="ALWAYS">

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button text="🔄  Refresh" onAction="#loadExpiryData"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 5; -fx-cursor: hand;"/>
            <Button fx:id="btnWriteOff" text="🗑  Write Off Selected Batch"
                    onAction="#handleWriteOff"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>

        <TableView fx:id="expiryTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colProduct"    text="Product Name"  prefWidth="220"/>
                <TableColumn fx:id="colBatchNo"    text="Batch No"      prefWidth="110"/>
                <TableColumn fx:id="colExpiry"     text="Expiry Date"   prefWidth="110"/>
                <TableColumn fx:id="colStock"      text="Qty On Hand"   prefWidth="100"/>
                <TableColumn fx:id="colTradePrice" text="Trade Price"   prefWidth="110"/>
                <TableColumn fx:id="colDaysLeft"   text="Days Left"     prefWidth="140"/>
                <TableColumn fx:id="colStatus"     text="Status"        prefWidth="130"/>
            </columns>
            <placeholder>
                <Label text="✅  No batches expiring within the next 90 days." style="-fx-text-fill: #27ae60;"/>
            </placeholder>
        </TableView>

        <Label text="🔴 Red = expired or ≤ 30 days     🟠 Orange = 31–60 days     🟡 Yellow = 61–90 days"
               style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
    </VBox>

</VBox>
