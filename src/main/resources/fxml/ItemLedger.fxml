<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" style="-fx-padding: 20;" styleClass="main-bg" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.my.pharmacy.controller.ItemLedgerController">

    <Label style="-fx-font-weight: bold;" styleClass="primary-text" text="ITEM LEDGER">
        <font><Font size="22.0" /></font>
    </Label>

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 15; -fx-border-color: #bdc3c7; -fx-background-color: white; -fx-border-radius: 10; -fx-background-radius: 10;" styleClass="card-bg">
        <Label style="-fx-font-weight: bold;" text="Find Medicine:" />
        <TextField fx:id="searchField" prefWidth="200" promptText="Type name to filter..." style="-fx-background-radius: 8;" />
        <ComboBox fx:id="productComboBox" prefWidth="250" promptText="Select from filtered list..." style="-fx-background-radius: 8;" />
        <Button onAction="#loadLedgerData" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 8;" text="Load Ledger" />
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab style="-fx-background-radius: 10 10 0 0;" text="1 - Sales History">
                <VBox>
                    <TableView fx:id="salesTable" style="-fx-background-radius: 0 0 10 10;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSaleDate" prefWidth="150" text="Date" />
                            <TableColumn fx:id="colInvoiceNo" prefWidth="100" text="Invoice No" />
                            <TableColumn fx:id="colSaleQty" prefWidth="100" text="Qty Sold" />
                            <TableColumn fx:id="colSaleRate" prefWidth="100" text="Rate" />
                            <TableColumn fx:id="colSaleTotal" prefWidth="120" text="Total Amount" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab style="-fx-background-radius: 10 10 0 0;" text="2 - Purchase History (Audit)">
                <VBox>
                    <TableView fx:id="purchaseHistoryTable" style="-fx-background-radius: 0 0 10 10;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colPurchDate" prefWidth="160" text="Date" />
                            <TableColumn fx:id="colDealerName" prefWidth="180" text="Dealer Name" />
                            <TableColumn fx:id="colInvoiceNoPurch" prefWidth="120" text="Invoice #" />
                            <TableColumn fx:id="colPurchasedQty" prefWidth="100" text="Initial Boxes" />
                            <TableColumn fx:id="colPurchCost" prefWidth="100" text="Cost Price" />
                            <TableColumn fx:id="colPurchTrade" prefWidth="100" text="Trade Price" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
