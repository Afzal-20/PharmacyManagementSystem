<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" styleClass="main-bg" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.my.pharmacy.controller.ItemLedgerController">

    <Label text="ITEM LEDGER" styleClass="primary-text" style="-fx-font-weight: bold;">
        <font><Font size="22.0"/></font>
    </Label>

    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="card-bg" style="-fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;">
        <Label text="Find Medicine:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="searchField" promptText="Type name to filter..." prefWidth="200"/>
        <ComboBox fx:id="productComboBox" prefWidth="250" promptText="Select from filtered list..."/>
        <Button text="Load Ledger" onAction="#loadLedgerData" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <tabs>
            <Tab text="1 - Sales History">
                <VBox>
                    <TableView fx:id="salesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSaleDate" text="Date" prefWidth="150"/>
                            <TableColumn fx:id="colInvoiceNo" text="Invoice No" prefWidth="100"/>
                            <TableColumn fx:id="colSaleQty" text="Qty Sold" prefWidth="100"/>
                            <TableColumn fx:id="colSaleRate" text="Rate" prefWidth="100"/>
                            <TableColumn fx:id="colSaleTotal" text="Total Amount" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="2 - Purchase History (Audit)">
                <VBox>
                    <TableView fx:id="purchaseHistoryTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colPurchDate" text="Date" prefWidth="160"/>
                            <TableColumn fx:id="colDealerName" text="Dealer Name" prefWidth="180"/>
                            <TableColumn fx:id="colInvoiceNoPurch" text="Invoice #" prefWidth="120"/>
                            <TableColumn fx:id="colPurchasedQty" text="Initial Boxes" prefWidth="100"/>
                            <TableColumn fx:id="colPurchCost" text="Cost Price" prefWidth="100"/>
                            <TableColumn fx:id="colPurchTrade" text="Trade Price" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>