<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" prefWidth="400" style="-fx-padding: 20; -fx-background-color: #f4f7f6;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.my.pharmacy.controller.ChangePasswordController">

    <Label text="CHANGE PASSWORD" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;">
        <font><Font size="18.0"/></font>
    </Label>
    <Separator/>

    <VBox spacing="10">
        <Label text="Current Password:" style="-fx-font-weight: bold;"/>
        <StackPane>
            <PasswordField fx:id="currentPassHidden" promptText="Enter current password"/>
            <TextField fx:id="currentPassText" promptText="Enter current password" visible="false"/>
        </StackPane>

        <Label text="New Password:" style="-fx-font-weight: bold;"/>
        <StackPane>
            <PasswordField fx:id="newPassHidden" promptText="Enter new password"/>
            <TextField fx:id="newPassText" promptText="Enter new password" visible="false"/>
        </StackPane>

        <Label text="Confirm New Password:" style="-fx-font-weight: bold;"/>
        <StackPane>
            <PasswordField fx:id="confirmPassHidden" promptText="Confirm new password"/>
            <TextField fx:id="confirmPassText" promptText="Confirm new password" visible="false"/>
        </StackPane>
    </VBox>

    <CheckBox fx:id="showPasswordCheckBox" text="Show Passwords" style="-fx-text-fill: #7f8c8d;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #bdc3c7;"/>
        <Button text="Save Password" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

</VBox>