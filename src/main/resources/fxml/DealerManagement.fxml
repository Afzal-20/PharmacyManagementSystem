<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.my.pharmacy.controller.DealerController">
    <VBox prefWidth="350" spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Manage Dealers" />
        <TextField fx:id="nameField" promptText="Contact Person Name" style="-fx-background-radius: 8;" />
        <TextField fx:id="companyField" promptText="Company/Distribution Name" style="-fx-background-radius: 8;" />
        <TextField fx:id="phoneField" promptText="Phone Number" style="-fx-background-radius: 8;" />
        <TextField fx:id="licenseField" promptText="Drug License No." style="-fx-background-radius: 8;" />
        <TextArea fx:id="addressField" prefHeight="80" promptText="Business Address" style="-fx-background-radius: 8; -fx-border-radius: 8;" />
        <HBox spacing="10">
            <Button onAction="#clearFields" prefWidth="100" style="-fx-background-color: #bdc3c7; -fx-background-radius: 8;" text="Clear" />
            <Button fx:id="btnSave" maxWidth="Infinity" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 8;" text="Save Dealer" HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <TextField fx:id="searchField" promptText="Search by Company or License..." style="-fx-background-radius: 8;" />
        <TableView fx:id="dealerTable" style="-fx-background-radius: 10; -fx-border-radius: 10;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCompany" prefWidth="150" style="-fx-background-radius: 10 0 0 0;" text="Company" />
                <TableColumn fx:id="colName" prefWidth="120" text="Contact Person" />
                <TableColumn fx:id="colPhone" prefWidth="100" text="Phone" />
                <TableColumn fx:id="colLicense" prefWidth="100" style="-fx-background-radius: 0 10 0 0;" text="License #" />
            </columns>
        </TableView>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button onAction="#handleEditSelection" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Edit Selected" />
            <Button onAction="#handleDeleteSelection" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Delete Selected" />
        </HBox>
    </VBox>
</HBox>
