<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.my.pharmacy.controller.POSController">

    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefHeight="20.0" prefWidth="134.0" text="SEARCH MEDICINE:" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
                <TextField fx:id="searchField" prefHeight="36.0" prefWidth="397.0" promptText="Type Name, Generic, or Batch..." style="-fx-font-size: 14; -fx-padding: 8; -fx-border-radius: 5px; -fx-background-color: #f4f7f6;" />
                <Button onAction="#loadStockData" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5px;" text="REFRESH" />
            </HBox>

            <HBox fx:id="customerSection" alignment="CENTER_LEFT" spacing="10">
                <Label prefHeight="20.0" prefWidth="133.0" text="SELECT CUSTOMER " textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
                <ComboBox fx:id="customerComboBox" prefHeight="30.0" prefWidth="358.0" promptText="Select Dealer/Client" style="-fx-font-size: 14; -fx-background-color: #f4f7f6;" />
                <Button onAction="#handleAddNewCustomer" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 50px;" text="+" />
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.6">
            <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f4f7f6;">
                <Label prefHeight="27.0" prefWidth="115.0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="AVAILABLE STOCK" />
                <TableView fx:id="productTable" prefHeight="471.0" prefWidth="695.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="180" text="Medicine Name" />
                        <TableColumn fx:id="colGeneric" prefWidth="120" text="Generic" />
                        <TableColumn fx:id="colBatch" prefWidth="100" text="Batch No" />
                        <TableColumn fx:id="colExpiry" prefWidth="100" text="Expiry" />
                        <TableColumn fx:id="colStock" prefWidth="80" text="Stock (Units)" />
                        <TableColumn fx:id="colPrice" prefWidth="100" text="Rate" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
                <Button maxWidth="Infinity" onAction="#handleAddToCart" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 12; -fx-font-weight: bold; -fx-background-radius: 5px;" text="ADD TO CART" />
            </VBox>

            <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f4f7f6;">
                <Label prefHeight="28.0" prefWidth="114.0" style="-fx-font-weight: bold; -fx-text-fill: #c0392b;" text="CURRENT INVOICE" />
                <TableView fx:id="cartTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCartName" prefWidth="150" text="Item" />
                        <TableColumn fx:id="colCartQty" prefWidth="50" text="Qty" />
                        <TableColumn fx:id="colCartPrice" prefWidth="80" text="Rate" />
                        <TableColumn fx:id="colCartDisc" prefWidth="80" text="Disc(Rs)" />
                        <TableColumn fx:id="colCartTotal" prefWidth="80" text="Total" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="20" style="-fx-padding: 15; -fx-background-color: #f4f7f6; -fx-border-color: #f4f7f6;">
                    <VBox alignment="CENTER_RIGHT" spacing="5">
                        <Label fx:id="totalLabel" text="Total: 0.00" textFill="#c0392b">
                            <font><Font name="System Bold" size="28.0" /></font>
                        </Label>
                        <HBox alignment="CENTER_RIGHT" spacing="10">
                            <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Amount Paid:" />
                            <TextField fx:id="amountPaidField" prefWidth="120" style="-fx-font-size: 16;" text="0.0" />
                        </HBox>
                        <Label fx:id="balanceDueLabel" text="Balance Due (Khata): 0.00" textFill="#e67e22">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                    </VBox>
                </HBox>

                <Button maxWidth="Infinity" onAction="#handleCheckout" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 16; -fx-padding: 15; -fx-font-weight: bold; -fx-background-radius: 5px;" text="COMPLETE SALE &amp; POST TO LEDGER" />
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
