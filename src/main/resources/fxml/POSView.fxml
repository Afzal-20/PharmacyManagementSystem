<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #2c3e50;" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.my.pharmacy.controller.POSController">

    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefHeight="20.0" prefWidth="134.0" text="SEARCH MEDICINE:" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
                <TextField fx:id="searchField" prefHeight="36.0" prefWidth="397.0" promptText="Type Name, Generic, or Batch..." style="-fx-font-size: 14; -fx-padding: 8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: #f4f7f6;" />
                <Button onAction="#loadStockData" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 100;" text="🔁" />
            </HBox>

            <HBox fx:id="customerSection" alignment="CENTER_LEFT" spacing="10">
                <Label prefHeight="20.0" prefWidth="133.0" text="SELECT CUSTOMER " textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
                <ComboBox fx:id="customerComboBox" prefHeight="30.0" prefWidth="358.0" promptText="Select Dealer/Client" style="-fx-font-size: 14; -fx-background-color: #f4f7f6; -fx-background-radius: 8;" />
                <Button onAction="#handleAddNewCustomer" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 100;" text="✚" />
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.5083444592790387" style="-fx-background-radius: 10 0 0 0;">

            <!-- LEFT: Product search table -->
            <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f4f7f6; -fx-background-radius: 10 0 0 0; -fx-border-radius: 10 0 0 0;">
                <Label prefHeight="27.0" prefWidth="115.0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="AVAILABLE STOCK" />
                <TableView fx:id="productTable" prefHeight="471.0" prefWidth="695.0" stylesheets="@../styles/tablestyles.css" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="180" style="-fx-background-radius: 10 0 0 0;" text="Medicine Name" />
                        <TableColumn fx:id="colGeneric" prefWidth="120" text="Generic" />
                        <TableColumn fx:id="colBatch" prefWidth="100" text="Batch No" />
                        <TableColumn fx:id="colExpiry" prefWidth="100" text="Expiry" />
                        <TableColumn fx:id="colStock" prefWidth="90" text="Stock (Units)" />
                        <TableColumn fx:id="colPrice" prefWidth="75" style="-fx-background-radius: 0 10 0 0;" text="Rate" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
                <Button maxWidth="Infinity" onAction="#handleAddToCart" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 12; -fx-font-weight: bold; -fx-background-radius: 8;" text="ADD TO CART  [Double-click or Enter]">
                    <VBox.margin><Insets top="8.0" /></VBox.margin>
                </Button>
            </VBox>

            <!-- RIGHT: Cart + payment -->
            <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f4f7f6;">
                <HBox alignment="CENTER_LEFT">
                    <Label prefHeight="28.0" prefWidth="401.0" style="-fx-font-weight: bold; -fx-text-fill: #c0392b;" text="CURRENT INVOICE" HBox.hgrow="ALWAYS" />
                    <!-- Remove from cart button — only enabled when a cart row is selected -->
                    <Button fx:id="btnRemoveFromCart" alignment="CENTER" ellipsisString="✕✕" onAction="#handleRemoveFromCart" prefHeight="28.0" prefWidth="161.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 14; -fx-background-radius: 8; -fx-font-size: 12;" text="✕  Remove">
                  <HBox.margin>
                     <Insets />
                  </HBox.margin></Button>
                </HBox>

                <TableView fx:id="cartTable" style="-fx-border-radius: 10; -fx-background-radius: 10;" stylesheets="@../styles/tablestyles.css" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCartName" prefWidth="150" style="-fx-background-radius: 10 0 0 0;" text="Item" />
                        <TableColumn fx:id="colCartQty" prefWidth="50" text="Qty" />
                        <TableColumn fx:id="colCartPrice" prefWidth="80" text="Rate" />
                        <TableColumn fx:id="colCartDisc" prefWidth="80" text="Disc(Rs)" />
                        <TableColumn fx:id="colCartTotal" prefWidth="80" style="-fx-background-radius: 0 10 0 0;" text="Total" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 15; -fx-background-color: #75889c; -fx-border-color: #75889c; -fx-background-radius: 10; -fx-border-radius: 10;">
                    <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="439.0" spacing="5" style="-fx-background-color: #75889c;">
                        <Label fx:id="totalLabel" prefHeight="40.0" prefWidth="429.0" text="Total: 0.00" textFill="#c0392b">
                            <font><Font name="System Bold" size="28.0" /></font>
                        </Label>
                        <HBox alignment="CENTER_RIGHT" prefHeight="38.0" prefWidth="423.0" spacing="10">
                            <Label prefHeight="19.0" prefWidth="290.0" style="-fx-font-size: 16; -fx-font-weight: bold;" text="Amount Paid:" />
                            <TextField fx:id="amountPaidField" prefHeight="30.0" prefWidth="496.0" style="-fx-font-size: 16; -fx-background-radius: 8;" text="0.0" />
                        </HBox>
                        <Label fx:id="balanceDueLabel" prefHeight="20.0" prefWidth="422.0" text="Balance Due : 0.00" textFill="#e67e22">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                    </VBox>
                    <VBox.margin><Insets top="8.0" /></VBox.margin>
                </HBox>

                <Button maxWidth="Infinity" onAction="#handleCheckout" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 16; -fx-padding: 15; -fx-font-weight: bold; -fx-background-radius: 8;" text="COMPLETE SALE  [F10]">
                    <VBox.margin><Insets top="8.0" /></VBox.margin>
                </Button>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
