<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainLayout" prefHeight="700.0" prefWidth="1100.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.my.pharmacy.controller.MainController">

    <left>
        <VBox prefWidth="220.0" spacing="5" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="0" right="0" top="20" />
            </padding>

            <VBox alignment="CENTER">
                <Label styleClass="app-title" text="PHARMACY" />
                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="WHOLESALE" />
                <padding>
                    <Insets bottom="30" />
                </padding>
            </VBox>

            <Button maxWidth="Infinity" onAction="#showDashboard" styleClass="nav-button" text="🏠  Home Dashboard" />

            <Button maxWidth="Infinity" onAction="#showPOS" styleClass="nav-button" text="🛒  Point of Sale" />
            <Button maxWidth="Infinity" onAction="#showInventory" styleClass="nav-button" text="📦  Inventory" />
            <Button maxWidth="Infinity" onAction="#showPurchaseEntry" styleClass="nav-button" text="➕  Stock Purchase" />

            <Button maxWidth="Infinity" onAction="#showCustomers" styleClass="nav-button" text="👥  Customers" />
            <Button maxWidth="Infinity" onAction="#showDealers" styleClass="nav-button" text="🏢  Dealers" />
            <Button maxWidth="Infinity" onAction="#showItemLedger" styleClass="nav-button" text="🔍  Item Ledger" />
            <Button maxWidth="Infinity" onAction="#showKhata" styleClass="nav-button" text="📘  Khata Ledgers" />
            <Button maxWidth="Infinity" onAction="#showHistory" styleClass="nav-button" text="📜  Sales History" />
            <Button fx:id="btnManageUsers" text="👥  Manage Users" maxWidth="Infinity" styleClass="nav-button" onAction="#showUserManagement"/>
            <VBox style="-fx-border-radius: 10px;" VBox.vgrow="ALWAYS" />

            <Button text="🔑  Change Password" maxWidth="Infinity" styleClass="nav-button" onAction="#showChangePassword"/>
            <Button maxWidth="Infinity" onAction="#handleLogout" style="-fx-text-fill: #e74c3c;" styleClass="nav-button" text="🚪  Logout" />

        </VBox>
    </left>

    <center>
    </center>

</BorderPane>
