# ============================================================
# Pharmacy Management System - Configuration File
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to: config.properties
#   2. Fill in your pharmacy's details below
#   3. Place config.properties in the same folder as the .jar
# ============================================================

# --- Database ---
# Name of the SQLite database file (created automatically on first run)
db.name=wholesale_pharmacy.db

# --- Pharmacy Info (printed on every invoice and receipt) ---
pharmacy.name=YOUR PHARMACY NAME
pharmacy.address=Shop No. X, Street Name, City
pharmacy.phone=0300-0000000

# --- PDF Settings ---
# Set to true to automatically open the PDF after every sale
# Set to false to only save it to the Desktop (faster checkout)
pdf.auto_open=true
